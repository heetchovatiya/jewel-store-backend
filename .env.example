# Jewel-Core Backend Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3001
NODE_ENV=production

# MongoDB Connection
# Keep one base URI and DB name is auto-selected by NODE_ENV:
# development -> priyincigold-dev
# production  -> priyincigold-prod
MONGODB_URI_BASE=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_PREFIX=priyincigold

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
FRONTEND_URL=https://your-store.vercel.app

# Email Configuration (for server scripts)
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# ============================================
# Digital Ocean Spaces (for image uploads)
# ============================================
# Get credentials from DO Control Panel > API > Spaces Keys
DO_SPACES_KEY=your_spaces_access_key
DO_SPACES_SECRET=your_spaces_secret_key
DO_SPACES_BUCKET=jewelstore
DO_SPACES_REGION=sgp1
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
DO_SPACES_CDN_URL=https://jewelstore.sgp1.digitaloceanspaces.com

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ============================================
# Automated DB Backup (DigitalOcean Spaces)
# ============================================
BACKUP_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/jewel_prod?retryWrites=true&w=majority
BACKUP_SPACE_NAME=your-space-name
BACKUP_S3_ENDPOINT=sgp1.digitaloceanspaces.com
BACKUP_TMP_DIR=./tmp_backups
